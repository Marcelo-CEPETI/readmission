# Garantir que grupo e morbidade_alta são fatores
descritiva_morb <- descritiva |> 
  filter(!is.na(morbidade_alta)) |>
  filter(grupo != "Óbito no 1º internamento") |> 
  mutate(
    grupo = factor(grupo),
    morbidade_alta = factor(morbidade_alta)
  )

# Obter os níveis
grupos <- levels(descritiva_morb$grupo)

# Comparações par a par
# Comparações par a par com limpeza automática
resultados_morb <- list()

for (comb in combn(grupos, 2, simplify = FALSE)) {
  dados_sub <- descritiva |>
    filter(grupo %in% comb, !is.na(morbidade_alta)) |>
    mutate(
      grupo = droplevels(factor(grupo)),
      morbidade_alta = droplevels(factor(morbidade_alta))
    )
  
  tab <- table(dados_sub$grupo, dados_sub$morbidade_alta)
  
  # Remove colunas (níveis) com total zero
  tab <- tab[, colSums(tab) > 0, drop = FALSE]
  
  print(paste("Comparação:", paste(comb, collapse = " vs ")))
  print(tab)
  
  if (ncol(tab) >= 2 && nrow(tab) == 2) {
    teste <- tryCatch({
      chisq.test(tab)$p.value
    }, error = function(e) NA)
  } else {
    teste <- NA
  }
  
  resultados_morb[[paste(comb, collapse = " vs ")]] <- teste
}

tibble::tibble(
  Comparação = names(resultados_morb),
  `p-valor (Qui-quadrado)` = unlist(resultados_morb)
)



