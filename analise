# Etapa de modelagem

## Modelo bruto

dados_model <- descritiva |> 
  filter(readmissao != "Óbito no 1º internamento")

dados_model2 <- dados_model |>
  filter(readmissao %in% c("Readmissão", "Alta no 1º internamento")) |>
  mutate(
    readm_bin = ifelse(readmissao == "Readmissão", 1, 0)
  )

model_bruto <- glm(
  readm_bin ~ `Idade (anos)` + 
    sexo + 
    fragilidade_number + 
    sofa +
    procedencia + 
    tipo_de_internamento + 
    convenio,
  family = binomial,
  data = dados_model2
)

tbl_regression(model_bruto, exponentiate = TRUE)

dados_auc <- model.frame(model_bruto)
prob_auc <- fitted(model_bruto)

library(pROC)

roc_obj <- roc(
  response = model.frame(model_bruto)$readm_bin,
  predictor = fitted(model_bruto)
)

auc(roc_obj)

plot(roc_obj, col = "blue", main = "Curva ROC - Modelo de Admissão")
coords(roc_obj, "best", ret = c("threshold", "sensitivity", "specificity"))

library(rms)

model_rms <- lrm(
  readm_bin ~ `Idade (anos)` + sexo + fragilidade_number + sofa +
    procedencia + tipo_de_internamento + convenio,
  data = dados_auc,
  x = TRUE,
  y = TRUE
)

cal <- calibrate(model_rms, method = "boot", B = 200)
plot(cal)
### O modelo apresentou excelente calibração, com erro absoluto médio de 0,004 após validação interna por bootstrap.

# probabilidades e estratos de risco
dados_auc$prob <- predict(model_bruto, type = "response")

dados_auc$risco <- ifelse(
  dados_auc$prob < 0.05, "Baixo risco",
  ifelse(dados_auc$prob < 0.10, "Risco intermediário", "Alto risco")
)

table(dados_auc$risco, dados_auc$readm_bin)
prop.table(table(dados_auc$risco, dados_auc$readm_bin), 1)

## Gráfico de estratificação

grafico_risco <- dados_auc |>
  group_by(risco) |>
  summarise(
    n = n(),
    n_readm = sum(readm_bin == 1),
    taxa_readm = mean(readm_bin == 1)
  ) |>
  mutate(
    risco = factor(risco, levels = c("Baixo risco", "Risco intermediário", "Alto risco"))
  )

grafico_risco

ggplot(grafico_risco, aes(x = risco, y = taxa_readm)) +
  geom_col(width = 0.65) +
  geom_text(
    aes(label = paste0(
      percent(taxa_readm, accuracy = 0.1),
      "\n(n=", n_readm, "/", n, ")"
    )),
    vjust = -0.5,
    size = 4.5
  ) +
  scale_y_continuous(
    labels = percent_format(accuracy = 1),
    limits = c(0, max(grafico_risco$taxa_readm) + 0.05)
  ) +
  labs(
    title = "Taxa de readmissão segundo estratificação de risco",
    subtitle = "Classificação baseada na probabilidade prevista pelo modelo",
    x = "Faixa de risco",
    y = "Taxa de readmissão"
  ) +
  theme_minimal(base_size = 14)

